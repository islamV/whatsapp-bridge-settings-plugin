{
    "name": "islamv/whatsapp-bridge-settings-plugin",
    "description": "Reusable WhatsApp bridge and settings plugin for Laravel and Filament.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Islamv\\WhatsappBridgeSettingsPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Islamv\\WhatsappBridgeSettingsPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Islamv\\WhatsappBridgeSettingsPlugin\\WhatsappBridgeSettingsPluginServiceProvider"
            ],
            "aliases": {
                "WhatsappBridge": "Islamv\\WhatsappBridgeSettingsPlugin\\Facades\\WhatsappBridge"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
